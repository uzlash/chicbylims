# Database - Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity Studio (for `npm run studio`)
SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production
SANITY_API_TOKEN=your_sanity_token_here

# Authentication - Next Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl

# Email Service - Resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=orders@yourdomain.com

# Admin Configuration
ADMIN_EMAIL=admin@yourdomain.com

# Currency (NGN to USD, e.g. 0.0006). NEXT_PUBLIC_ for client; NGN_TO_USD_RATE for server.
NEXT_PUBLIC_NGN_TO_USD_RATE=0.0006
NGN_TO_USD_RATE=0.0006

# Paystack (local payments, NGN)
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# Stripe (international payments, USD)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
